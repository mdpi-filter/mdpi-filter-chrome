{
  "homepage_url": "https://mdpi-filter.pages.dev/",
  "background": {
    "service_worker": null,
    "type": null,
    "scripts": [
      "shared/integrity.js",
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mdpi-filter@mdpi-filter.org",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": [
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
